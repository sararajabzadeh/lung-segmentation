   "source": [
    "import torch\n",
    "from lungseg.models import UNet\n",
    "\n",
    "model = UNet()\n",
    "x = torch.randn(1, 1, 256, 256)\n",
    "\n",
    "for i, down in enumerate(model.downs):\n",
    "    x = down(x)\n",
    "    print(f\"level {i} after DoubleConv:\", tuple(x.shape))\n",
    "    x = model.pool(x)\n",
    "    print(f\"level {i} after pool:     \", tuple(x.shape))"
   ]
